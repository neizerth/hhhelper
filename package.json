{
  "name": "hhhelper",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:browser": "VITE_EXTENSION_AUTO_LAUNCH=true vite",
    "build": "vite build",
    "release": "bash scripts/release.sh",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write .",
    "smui-theme": "smui-theme compile public/smui.css -i src/theme",
    "prepare": "lefthook install && pnpm smui-theme"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@smui/button": "^9.0.1",
    "@smui/paper": "^9.0.1",
    "@smui/textfield": "^9.0.1",
    "@smui/top-app-bar": "^9.0.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/ramda": "^0.32.0",
    "@types/webextension-polyfill": "^0.10.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "sass": "^1.101.0",
    "smui-theme": "^9.0.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-material-ui": "^9.0.1",
    "tslib": "^2.6.3",
    "typescript": "~5.6.3",
    "vite": "^5.4.4",
    "vite-plugin-web-extension": "^4.1.6",
    "vitest": "^3.2.4",
    "webextension-polyfill": "^0.10.0"
  },
  "dependencies": {
    "ramda": "^0.32.0"
  }
}
